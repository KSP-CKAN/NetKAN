identifier: ProcAirships
name: ProcAirships
abstract: Procedural Airships - A ProceduralParts Expansion
$kref: '#/ckan/github/ItMustBeACamel/ProcAirships'
$vref: '#/ckan/ksp-avc'
ksp_version: 0.90.0
