tags:
  - plugin
  - parts
depends:
  - name: ProceduralParts
install:
  - find: ProcAirships
    install_to: GameData
  - file: Ships
    install_to: Ships
  - file: saves/training/airship_flight.sfs
    install_to: Tutorial
  - file: saves/training/airship_flight_far.sfs
    install_to: Tutorial
